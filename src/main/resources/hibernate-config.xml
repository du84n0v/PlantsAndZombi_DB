<?xml version="1.0" encoding="utf-8"?>
<hibernate-configuration>
    <session-factory>
        <property name="hibernate.dialect">org.hibernate.dialect.PostgreSQL82Dialect</property>
        <property name="hibernate.connection.driver_class">org.postgresql.Driver</property>
        <property name="hibernate.connection.username">plants_user</property>
        <property name="hibernate.connection.password">12345</property>
        <property name="hibernate.connection.url">jdbc:postgresql://localhost:8081/plants_db</property>
        <property name="hbm2ddl.auto">update</property>
        <property name="show_sql">true</property>

        <!-- MAPPINGS -->
        <mapping class="entity.Plant"/>
        <mapping class="entity.Customer"/>
        <mapping class="entity.IndividualCustomer"/>
        <mapping class="entity.CorporativeCustomer"/>
        <mapping class="entity.Supplier"/>
        <mapping class="entity.PlantPrice"/>
        <mapping class="entity.Purchase"/>


    </session-factory>

</hibernate-configuration>
